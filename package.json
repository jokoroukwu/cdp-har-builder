{
  "name": "cdp-har-builder",
  "version": "0.1.0",
  "description": "Build HAR files from Chromium DevTools Protocol network events",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc"
  },
  "keywords": [
    "cdp",
    "har",
    "chromium",
    "devtools",
    "network"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
